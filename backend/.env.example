PORT=4000
NODE_ENV=development

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fin_agri_score?schema=public"

INFERENCE_SERVICE_URL="http://localhost:8000"
ARTIFACTS_DIR="../artifacts/output"

CORS_ORIGIN="http://localhost:5173"

FIN_AGRI_SCORE_MIN=300
FIN_AGRI_SCORE_MAX=850
RISK_BAND_LOW_MIN=700
RISK_BAND_MEDIUM_MIN=550

# Re-score: blend new model probs with previous score when ONLY these feature_columns change (comma-separated).
# Set to "none" to disable minor-field blending entirely.
RESCORE_MINOR_BLEND_KEYS=chirps_rain_30d_mm,chirps_rain_90d_mm,modis_ndvi_90d_mean,modis_ndvi_90d_std,regional_yield_mean
# Weight on previous class probabilities (0 = off). Example: 0.55 favours stability when env fields drift slightly.
RESCORE_MINOR_BLEND_ALPHA=0.55
